%%%%%%%%%%%%%%%%%%   Box Definitions %%%%%%%%%%%%%%%%%%%%%
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\newtcolorbox[auto counter]{example}[1][]{
  yellow-labeled,
  title=\textbf{Example \thetcbcounter \ ({#1})},
}

\newtcolorbox[auto counter]{custom-big}[1][]{
  pink-labeled,
  title=\textbf{{#1}},
}

\newtcolorbox[auto counter]{custom-two}[1][]{
  red-labeled,
  title=\textbf{{#1}},
}

\newtcolorbox[auto counter]{conclusion}{
  red-labeled,
  title=\textbf{Conclusion},
}

\newtcolorbox{definition}{
    one-sided-red,
    title=\textbf{Definition},
}

\newtcolorbox{theorem}{
    one-sided-blue,
    title=\textbf{Theorem},
}
\newtcolorbox{solution}{
    one-sided-blue,
    title=\textbf{Solution},
}
\newtcolorbox{challenge}{
    red-labeled,
    title=\textbf{Challenge},
}

\newtcolorbox{exercise}{
    one-sided-purple,,
    title=\textbf{Exercise}
}

\newtcolorbox{prooff}{
    one-sided-pink,
    title=\textbf{Proof}
}

\newtcolorbox{custom-small}[1][]{
    one-sided-purple,
    title=\textbf{{#1}},
}
\newtcolorbox{formula}{
    one-sided-red,
    title=\textbf{Formula},
}

\newtcolorbox[auto counter]{custom-simple}[1][]{
    simple,
    title={#1},
    % add a `\thetcbcounter` to the end if you want to keep track of numberings.
}